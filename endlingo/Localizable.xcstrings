    "가입한 이메일을 입력하면\n비밀번호 재설정 링크를 보내드립니다": {
      "comment": "An alert message that appears when a user successfully requests a password reset link to be sent to their email address.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "登録済みのメールアドレスを入力すると\nパスワード再設定用のリンクを送信します"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập email đã đăng ký\nchúng tôi sẽ gửi liên kết đặt lại mật khẩu"
          }
        }
      }
    },
